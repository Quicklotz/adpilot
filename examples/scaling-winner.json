{
  "name": "Scale Winning Ad to New Markets",
  "description": "Template for scaling a proven winning ad creative into multiple countries/markets",
  "variables": {
    "product_name": { "type": "string", "description": "Name of the product or service" },
    "winning_headline": { "type": "string", "description": "The proven headline from your winning ad" },
    "winning_body": { "type": "string", "description": "The proven body copy from your winning ad" },
    "landing_url": { "type": "string", "description": "Landing page URL" },
    "daily_budget": { "type": "number", "default": 2500, "description": "Daily budget in cents per ad set ($25/day)" },
    "image_hash": { "type": "string", "description": "Meta image hash of the winning creative" }
  },
  "campaign": {
    "name": "{{product_name}} - Scale Winner",
    "objective": "OUTCOME_TRAFFIC",
    "special_ad_categories": ["NONE"],
    "status": "PAUSED"
  },
  "adsets": [
    {
      "name": "{{product_name}} - US Market",
      "billing_event": "IMPRESSIONS",
      "optimization_goal": "LINK_CLICKS",
      "daily_budget": "{{daily_budget}}",
      "targeting": {
        "geo_locations": { "countries": ["US"] },
        "age_min": 18,
        "age_max": 65
      },
      "status": "PAUSED"
    },
