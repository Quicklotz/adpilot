{
  "name": "adpilot",
  "version": "1.0.0",
  "description": "A powerful CLI for the Meta/Facebook Marketing API — manage campaigns, ad sets, ads, creatives, and insights from your terminal.",
  "main": "dist/index.js",
  "bin": {
    "adpilot": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "facebook",
    "meta",
    "marketing",
    "ads",
    "cli",
    "campaign",
    "advertising",
    "graph-api"
  ],
  "author": "connor odea <connor@quicklotz.com>",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^10.2.0",
    "inquirer": "^8.2.6",
    "node-fetch": "^2.7.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.14.0",
    "@types/node-fetch": "^2.6.11",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
