{
  "name": "adpilot",
  "version": "1.0.0",
  "description": "A powerful CLI for the Meta/Facebook Marketing API — manage campaigns, ad sets, ads, creatives, and insights from your terminal.",
  "main": "dist/index.js",
  "bin": {
    "adpilot": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "NODE_OPTIONS='--localstorage-file=/tmp/adpilot-jest-ls' jest",
    "test:coverage": "NODE_OPTIONS='--localstorage-file=/tmp/adpilot-jest-ls' jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "facebook",
    "meta",
    "marketing",
    "ads",
    "cli",
    "campaign",
    "advertising",
    "graph-api"
  ],
  "author": "connor odea <connor@quicklotz.com>",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^10.2.0",
    "inquirer": "^8.2.6",
    "node-fetch": "^2.7.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "@types/node-fetch": "^2.6.11",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/connorodea/adpilot.git"
  },
  "bugs": {
    "url": "https://github.com/connorodea/adpilot/issues"
  },
  "homepage": "https://github.com/connorodea/adpilot#readme",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16.0.0"
  }
}
